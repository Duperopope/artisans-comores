# Supabase — Google OAuth for admin CMS
# Source values from the Kairos Forge shared Supabase project (same as kairos-forge-boilerplate).
# Enable Google provider in Supabase Auth and add the deployed URL + /auth/callback
# to the "Redirect URLs" allowlist before signing in.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional: site base path on GitHub Pages (set by CI automatically)
# NEXT_PUBLIC_BASE_PATH=/artisans-comores
