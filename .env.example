# CMS admin password (required — set a strong password in production)
CMS_PASSWORD=change-me

# HMAC secret for session tokens (required — set a long random string in production)
CMS_SECRET=change-me-to-a-random-32-char-string

# Comma-separated list of admin email addresses allowed to log in
ADMIN_EMAILS=s.medjaher@gmail.com,s.medjajher@gmail.com

# Vercel KV / Upstash Redis (required in production — auto-injected by Vercel KV integration)
# When unset, CMS falls back to the local JSON file (dev only — not persisted on Vercel).
KV_REST_API_URL=
KV_REST_API_TOKEN=
